{
  "name": "one-click-invest",
  "version": "0.1.0",
  "private": true,
  "description": "A Strapi application",
  "scripts": {
    "build": "strapi build",
    "deploy": "strapi deploy",
    "develop": "strapi develop",
    "start": "strapi start",
    "strapi": "strapi",
    "dev": "concurrently \"strapi develop\" \"npm run 11ty\" \"npm run watch:css\"",
    "11ty": "eleventy --serve",
    "build:css": "tailwindcss -i ./src/assets/styles/tailwind.css -o ./src/_includes/assets/styles.css --minify",
    "watch:css": "tailwindcss -i ./src/assets/styles/tailwind.css -o ./src/_includes/assets/styles.css --watch"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@strapi/plugin-cloud": "5.4.1",
    "@strapi/plugin-users-permissions": "5.4.1",
    "@strapi/strapi": "5.5.0",
    "axios": "^1.7.7",
    "better-sqlite3": "11.3.0",
    "node-fetch": "^3.3.2",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "eleventy-plugin-postcss": "^1.0.4",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0 <=22.x.x",
    "npm": ">=6.0.0"
  },
  "strapi": {
    "uuid": "c260579f-c4d9-4460-848f-26cc4889477f"
  }
}
