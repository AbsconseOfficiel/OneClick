<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <link rel="stylesheet" href="./assets/styles.css">
  <!-- Font et favicon -->
  <link href="https://db.onlinewebfonts.com/c/c4d8819fda4c3fd79e36cedcc8d422bb?family=Halyard+Display" rel="stylesheet">
  <script type="text/javascript" src="scripts.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Host+Grotesk:ital,wght@0,300..800;1,300..800&display=swap" rel="stylesheet">
  <link rel="icon" href="/assets/favicon.ico" type="image/x-icon">
</head>
<body class="text-white font-text antialiased bg-neutral-950">
  <!-- Header -->
    {% block header %}{% endblock %}

  <div id="blob-container"></div>

  <!-- Contenu principal -->
  <main text-white">
    {% block content %}{% endblock %}
  </main>

  <!-- Footer -->
  <footer class="bg-neutral-900 border-t border-gray-700 text-gray-300 relative">
    <div class="max-w-screen-2xl mx-auto">
      <div class="container mx-auto flex justify-between py-6 items-center text-center relative z-10 px-10">
        <!-- Texte à gauche -->
        <p class="text-white text-lg md:text-2xl font-semibold drop-shadow-md">
          Impliquez, Financez, Accélérez !
        </p>

        <!-- Liens à droite -->
        <div class="space-x-4 text-sm">
          <a href="/mentions-legales" class="hover:text-white transition">Mentions légales</a>
          <a href="/politique-confidentialite" class="hover:text-white transition">Politique de confidentialité</a>
        </div>
      </div>

      <!-- Attribution en bas -->
      <div class="text-center pt-4 border-t border-gray-700 py-6 text-sm">
        <p>
          &copy; 2024 OneClick Invest. Tous droits réservés.
        </p>
        <p>
          🎨 Design by <a href="/politique-confidentialite" class="font-bold">DYLAN ENJOLVIN</a>
        </p>
      </div>
    </div>
  </footer>

</body>
</html>
