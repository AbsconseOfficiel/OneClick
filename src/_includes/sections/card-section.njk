<div class="container mx-auto">
  <h2 class="font-display text-4xl mb-14 max-w-[35rem]">
    {{ section.title }}
  </h2>
  {% if section.cards %}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {% for card in section.cards %}
        <div class="bg-neutral-900 p-9 py-6 rounded-2xl flex flex-col justify-between">
          <div>
            <h3 class="font-display text-3xl mb-4">{{ card.title }}</h3>
            <p class="text-neutral-400 mb-7 text-sm">{{ card.description }}</p>
          </div>

          {% if card.popup %}
          <button 
            class="inline-flex items-center rounded-lg bg-yellow-400 text-black py-3 px-3 hover:bg-yellow-300 transition-all duration-300 mt-4 w-min"
            onclick="openPopup('{{ card.popup.content }}')">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24">
              <path d="M11.293 4.707 17.586 11H4v2h13.586l-6.293 6.293 1.414 1.414L21.414 12l-8.707-8.707-1.414 1.414z" />
            </svg>
          </button>

          <!-- Pop-up Template -->
          <div id="popup" class="fixed inset-0 bg-black bg-opacity-50 hidden flex items-center justify-center z-50">
            <div class="bg-neutral-900 p-8 rounded-lg max-w-lg w-full relative">
              <button 
                class="absolute top-3 right-3 text-neutral-400 hover:text-white transition" 
                onclick="closePopup()">
                ✕
              </button>
              <div id="popup-content" class="text-neutral-200">
                <!-- Le contenu de la pop-up sera inséré ici -->
              </div>
            </div>
          </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  {% endif %}
</div>
