<section class="cards">
  <div class="container">
    <h2>{{ section.title }}</h2>
    {% if section.subtitle %}
      <p>{{ section.subtitle }}</p>
    {% endif %}
    <div class="card-list">
      {% for card in section.cards %}
        <div class="card">
          <h3>{{ card.title }}</h3>
          <p>{{ card.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
